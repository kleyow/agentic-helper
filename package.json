{
  "name": "agentic-helper",
  "version": "1.0.0",
  "description": "CLI tool to scaffold and maintain AI assistant context files for your repository",
  "type": "module",
  "bin": {
    "agentic-helper": "./bin/agentic-helper.js",
    "agh": "./bin/agentic-helper.js"
  },
  "main": "./src/index.js",
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node bin/agentic-helper.js",
    "lint": "eslint src/ bin/",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "keywords": [
    "ai",
    "claude",
    "copilot",
    "cursor",
    "agents",
    "cli",
    "scaffold",
    "developer-tools"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "chalk": "5.3.0",
    "commander": "12.1.0",
    "inquirer": "9.3.7",
    "ora": "8.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
